@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Inter:wght@400;600;700;800&display=swap');
@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');

:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #1c2330;
  --surface3: #222a38;
  --surface4: #2a3444;
  --border: rgba(255,255,255,0.1);
  --border2: rgba(255,255,255,0.06);
  --orange: #F97316;
  --yellow: #FACC15;
  --green: #22C55E;
  --red: #EF4444;
  --blue: #3B82F6;
  --text: #E6EDF3;
  --muted: #6E7681;
  --muted2: #9198A1;
  --mono: 'DM Mono', monospace;
  --disp: 'Inter', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: var(--disp); min-height: 100vh; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; font-family: var(--mono); }
input, select, textarea { font-family: var(--mono); background: var(--surface2); border: 0.5px solid var(--border); color: var(--text); border-radius: 6px; padding: 8px 12px; font-size: 12px; outline: none; width: 100%; }
input:focus, select:focus, textarea:focus { border-color: rgba(249,115,22,0.4); }